# Porta do servidor (Railway injeta $PORT automaticamente)
PORT=3001

# URL da base de dados MySQL
# Railway:   mysql://user:pass@host:3306/dbname
# Local:     mysql://root:@localhost:3306/bisca61_node
DATABASE_URL="mysql://root:@localhost:3306/bisca61_node"

# Ambiente
NODE_ENV=production

# Origens CORS permitidas (separadas por vírgula)
# Deixar * para aceitar tudo (desenvolvimento) ou especificar domínios em produção
# Exemplo: https://bisca61.railway.app,https://meudominio.com
ALLOWED_ORIGINS=*
